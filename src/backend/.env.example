# KSP AI Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# The app will work without these (graceful degradation), but Gemini requires an API key.

# ================================================================
# 🔑 GEMINI AI (Required for real LLM intelligence briefs)
# Get a FREE key in 30 seconds at: https://aistudio.google.com/app/apikey
# ================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# ================================================================
# Database (default values work with docker-compose)
# ================================================================
DATABASE_URL=postgresql://ksp_admin:ksp_password@localhost:5432/ksp_db
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379/0

# ================================================================
# Security (Keycloak — optional for dev, bypass is active)
# ================================================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=master
