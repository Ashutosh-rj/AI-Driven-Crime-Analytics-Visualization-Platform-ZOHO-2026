# =============================================================================
# KSP AI Platform — .gitignore
# =============================================================================

# ─── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
dist/
build/
.vite/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
*.tsbuildinfo

# ─── Python / Backend ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ─── Environment & Secrets (NEVER COMMIT THESE) ───────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
# Note: .env.example is intentionally NOT ignored — it's a template for others

# ─── API Keys & Credentials ──────────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt
secrets/
credentials/
service-account*.json

# ─── Database Files ──────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
ksp_ai.db
# PostgreSQL dumps
*.sql.gz
*.dump

# ─── ML Model Artifacts (large binary files — use DVC or HuggingFace Hub) ───
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.pkl
*.pickle
*.joblib
# HuggingFace model cache
.cache/
models/
checkpoints/

# ─── Docker ──────────────────────────────────────────────────────────────────
.docker/
docker-compose.override.yml

# ─── Testing & Coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
.hypothesis/
nosetests.xml
test-results/

# ─── Alembic (migration state — keep versions/, ignore local state) ──────────
# DO commit: alembic/versions/*.py
# DON'T commit: local alembic state files
alembic/env.pyc

# ─── Logs & Runtime ──────────────────────────────────────────────────────────
*.log
logs/
*.pid
celerybeat-schedule
celerybeat.pid

# ─── OS Generated Files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── IDE / Editor ────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── Monitoring & Observability (local runtime data) ─────────────────────────
prometheus_data/
grafana_data/

# ─── Qdrant local storage (re-seeded on startup) ─────────────────────────────
qdrant_storage/

# ─── Jupyter Notebooks checkpoints ───────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Miscellaneous ───────────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.scratch/
tmp/

# ─── Datathon Specific Ignores ───────────────────────────────────────────────
image.tar
.venv_trivy/
tags.json

# ─── Zoho Catalyst ───────────────────────────────────────────────────────────
.catalyst/
.catalystrc
catalyst.log
